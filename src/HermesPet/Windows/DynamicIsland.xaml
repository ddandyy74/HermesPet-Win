<Window x:Class="HermesPet.Windows.DynamicIslandWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:local="clr-namespace:HermesPet.Windows"
         xmlns:models="clr-namespace:HermesPet.Models"
         mc:Ignorable="d"
         WindowStyle="None"
         AllowsTransparency="True"
         Topmost="True"
         ShowInTaskbar="False"
         Background="Transparent"
         Width="280"
         Height="36"
         x:Name="DynamicIslandRoot">

    <Window.Resources>
        <!-- 胶囊形状模板 -->
        <ControlTemplate x:Key="CapsuleTemplate" TargetType="ContentControl">
            <Grid>
                <!-- 胶囊背景 -->
                <Border x:Name="CapsuleBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="18"
                        BorderThickness="0">
                    <ContentPresenter HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </ControlTemplate>

        <!-- 状态背景色转换器 -->
        <local:StateToBackgroundConverter x:Key="StateToBackgroundConverter"/>
        
        <!-- 连接状态颜色转换器（M3.3） -->
        <local:ConnectionStatusToColorConverter x:Key="ConnectionStatusToColorConverter"/>

        <!-- 展开动画（紧凑态 → 扩展态） -->
        <!-- 触发：Idle → Hovering -->
        <!-- 时长：300ms -->
        <!-- 缓动：CubicEase EaseOut -->
        <!-- 注意：移除 From 属性，让动画从当前值开始 -->
        <Storyboard x:Key="ExpandAnimation"
                    Duration="0:0:0.300"
                    Completed="OnExpandAnimationCompleted">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                           To="360"
                           Duration="0:0:0.300">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Height"
                           To="80"
                           Duration="0:0:0.300">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 收起动画（扩展态 → 紧凑态） -->
        <!-- 触发：Hovering → Idle -->
        <!-- 时长：200ms -->
        <!-- 缓动：CubicEase EaseIn -->
        <!-- 注意：移除 From 属性，让动画从当前值开始 -->
        <Storyboard x:Key="CollapseAnimation"
                    Duration="0:0:0.200"
                    Completed="OnCollapseAnimationCompleted">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                           To="180"
                           Duration="0:0:0.200">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Height"
                           To="40"
                           Duration="0:0:0.200">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 流式传输脉冲动画 -->
        <!-- 触发：State == Streaming -->
        <!-- 周期：1.5s 循环 -->
        <Storyboard x:Key="StreamingPulseAnimation"
                    RepeatBehavior="Forever"
                    Duration="0:0:1.5">
            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                         Storyboard.TargetName="CapsuleBorder">
                <EasingColorKeyFrame KeyTime="0:0:0.0" Value="#0A84FF"/>
                <EasingColorKeyFrame KeyTime="0:0:0.75" Value="#064582"/>
                <EasingColorKeyFrame KeyTime="0:0:1.5" Value="#0A84FF"/>
            </ColorAnimationUsingKeyFrames>
        </Storyboard>

        <!-- 错误状态闪烁动画 -->
        <!-- 触发：State == Error -->
        <!-- 周期：500ms 循环 -->
        <Storyboard x:Key="ErrorFlashAnimation"
                    RepeatBehavior="Forever"
                    Duration="0:0:0.500">
            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                         Storyboard.TargetName="CapsuleBorder">
                <EasingColorKeyFrame KeyTime="0:0:0.0" Value="#FF453A"/>
                <EasingColorKeyFrame KeyTime="0:0:0.25" Value="#CC3630"/>
                <EasingColorKeyFrame KeyTime="0:0:0.50" Value="#FF453A"/>
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

     <!-- 主容器 -->
    <Grid>
        <!-- 胶囊形动态岛 -->
        <ContentControl x:Name="IslandContentControl"
                       Template="{StaticResource CapsuleTemplate}"
                       Background="{Binding State, Converter={StaticResource StateToBackgroundConverter}}">
            <Grid Margin="16,0">
                <!-- M3.3: 连接状态指示器（右上角小圆点） -->
                <Ellipse Width="8"
                        Height="8"
                        Fill="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusToColorConverter}}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,-8,0">
                    <!-- ConnectionStatus 连接提示 -->
                    <Ellipse.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="连接状态: "/>
                                <TextBlock Text="{Binding ConnectionStatus}"/>
                            </StackPanel>
                        </ToolTip>
                    </Ellipse.ToolTip>
                </Ellipse>
                
                <!-- Idle/Hovering 状态：显示 AI 模式图标和名称 -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter='Idle,Hovering'}">
                    <!-- AI 模式图标（占位，后续用真实图标替换） -->
                    <TextBlock Text="🤖" FontSize="16" VerticalAlignment="Center"/>
                    
                    <!-- AI 模式名称 -->
                    <TextBlock Text="{Binding StateText}"
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="White"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Streaming 状态：显示思考动画 -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Streaming}">
                    <!-- 脉冲动画指示器 -->
                    <TextBlock Text="💫" FontSize="16" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="正在思考..."
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="White"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ToolProgress 状态：显示工具进度 -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=ToolProgress}">
                    <TextBlock Text="🔧" FontSize="16" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding StateText}"
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="White"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- VoiceActive 状态：显示语音波形 -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=VoiceActive}">
                    <TextBlock Text="🎤" FontSize="16" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="正在聆听..."
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="White"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Permission 状态：显示权限请求 -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Permission}">
                    <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding StateText}"
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="White"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Error 状态：显示错误信息 -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Error}">
                    <TextBlock Text="❌" FontSize="16" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding ErrorMessage}"
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="White"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             MaxWidth="200"/>
                </StackPanel>
            </Grid>
        </ContentControl>
    </Grid>
</Window>
