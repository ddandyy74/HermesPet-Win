<Window x:Class="HermesPet.Windows.QuickAskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HermesPet.ViewModels"
        Title="Quick Ask"
        Width="680"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- 毛玻璃效果 -->
        <SolidColorBrush x:Key="GlassBrush" Color="#F2F2F7" Opacity="0.95"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8E8E93"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007AFF"/>

        <!-- 圆角样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 主卡片 -->
        <Border Style="{StaticResource CardStyle}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 输入区（紧凑态） -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- AI 模式图标 -->
                    <TextBlock Grid.Column="0"
                               Text="🤖"
                               FontSize="24"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <!-- 输入框 -->
                    <TextBox Grid.Column="1"
                             Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextBrush}"
                             VerticalAlignment="Center"
                             Padding="8"
                             AcceptsReturn="False"
                             KeyDown="OnInputKeyDown">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SubmitCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- 上下文提示 -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding SourceAppName, StringFormat='来自 {0}'}"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Visibility="{Binding SelectedContext, Converter={StaticResource StringToVisibilityConverter}}"/>
                </Grid>

                <!-- 回答区（展开态） -->
                <Grid Grid.Row="1"
                      Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 问题标题 -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding LastQuestion}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8"/>

                    <!-- 回答内容 -->
                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="300"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding Answer}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Padding="8"/>
                    </ScrollViewer>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <!-- 复制按钮 -->
                        <Button Content="📋 复制"
                                Command="{Binding CopyAnswerCommand}"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Background="{StaticResource GlassBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"/>

                        <!-- Pin 按钮 -->
                        <Button Content="📌 Pin"
                                Command="{Binding PinCommand}"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Background="{StaticResource GlassBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"/>

                        <!-- 迁移按钮 -->
                        <Button Content="💬 聊天窗"
                                Command="{Binding MigrateToChatCommand}"
                                Padding="12,6"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
