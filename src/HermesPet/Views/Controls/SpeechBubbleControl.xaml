<UserControl x:Class="HermesPet.Views.Controls.SpeechBubbleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="160"
             x:Name="Root">
    
    <Grid>
        <!-- 气泡容器 -->
        <Border x:Name="BubbleBorder"
                Background="#D1000000"
                BorderBrush="#73D77855"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Effect="{StaticResource BubbleShadow}"
                Visibility="Collapsed">
            
            <TextBlock x:Name="BubbleText"
                       Text="{Binding Text, ElementName=Root}"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="Medium"
                       FontFamily="Segoe UI"
                       TextWrapping="NoWrap"
                       TextTrimming="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
    
    <UserControl.Resources>
        <!-- 气泡阴影效果 -->
        <DropShadowEffect x:Key="BubbleShadow"
                          Color="Black"
                          Opacity="0.30"
                          BlurRadius="6"
                          ShadowDepth="2"
                          Direction="270"/>
        
        <!-- 显示动画 -->
        <Storyboard x:Key="ShowBubbleAnimation">
            <DoubleAnimation Storyboard.TargetName="BubbleBorder"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BubbleBorder"
                           Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                           From="0.6" To="1"
                           Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BubbleBorder"
                           Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                           From="0.6" To="1"
                           Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- 隐藏动画 -->
        <Storyboard x:Key="HideBubbleAnimation">
            <DoubleAnimation Storyboard.TargetName="BubbleBorder"
                           Storyboard.TargetProperty="Opacity"
                           From="1" To="0"
                           Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BubbleBorder"
                           Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                           From="1" To="0.8"
                           Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BubbleBorder"
                           Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                           From="1" To="0.8"
                           Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
</UserControl>
