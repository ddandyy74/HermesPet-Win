<Window x:Class="HermesPet.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HermesPet.ViewModels"
        xmlns:controls="clr-namespace:HermesPet.Views.Controls"
        xmlns:converters="clr-namespace:HermesPet.Converters"
        mc:Ignorable="d"
        Title="HermesPet"
        Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        d:DataContext="{d:DesignInstance vm:ChatViewModel}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 对话标签样式 -->
        <Style x:Key="ConversationTabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEBEB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 激活对话标签样式 -->
        <Style x:Key="ActiveConversationTabStyle" TargetType="Button" BasedOn="{StaticResource ConversationTabStyle}">
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 发送按钮样式 -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：会话列表侧边栏（M3.1 多会话管理） -->
        <controls:ConversationListControl Grid.Column="0"
                                          Width="250"
                                          DataContext="{Binding}"/>

        <!-- 右侧：聊天主区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部：AI 模式选择器 -->
            <Border Grid.Row="0"
                   Background="White"
                   BorderBrush="#E0E0E0"
                   BorderThickness="0,0,0,1"
                   Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 当前会话标题 -->
                    <TextBlock Grid.Column="0"
                              Text="{Binding ActiveConversation.Title, Mode=OneWay}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              TextTrimming="CharacterEllipsis"/>

                    <!-- AI 模式下拉菜单 -->
                    <ComboBox Grid.Column="1"
                             SelectedIndex="0"
                             Width="150"
                             VerticalAlignment="Center">
                        <ComboBoxItem Content="⚡ Hermes"/>
                        <ComboBoxItem Content="🌐 在线 AI"/>
                        <ComboBoxItem Content="🦀 OpenClaw"/>
                        <ComboBoxItem Content="🤖 Claude Code"/>
                        <ComboBoxItem Content="💻 Codex"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 中间：消息列表 -->
            <ScrollViewer Grid.Row="1"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Padding="8"
                         Background="#FAFAFA">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:MessageBubble Message="{Binding}"
                                                   AgentMode="{Binding DataContext.AgentMode, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 底部：输入区域 -->
            <Border Grid.Row="2"
                   Background="White"
                   BorderBrush="#E0E0E0"
                   BorderThickness="0,1,0,0"
                   Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 输入框 -->
                    <TextBox Grid.Column="0"
                            Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                            FontSize="14"
                            Padding="8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            VerticalScrollBarVisibility="Auto"
                            MaxHeight="120"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Modifiers="Ctrl"
                                       Command="{Binding SendMessageCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- 发送按钮 -->
                    <Button Grid.Column="1"
                           Content="发送"
                           Command="{Binding SendMessageCommand}"
                           Style="{StaticResource SendButtonStyle}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 错误提示 Toast -->
        <Border Grid.Column="0"
               Grid.ColumnSpan="2"
               Background="#FF4444"
               Padding="16,8"
               CornerRadius="4"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,60,0,0"
               Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                      Foreground="White"
                      FontSize="13"/>
        </Border>
    </Grid>
</Window>
