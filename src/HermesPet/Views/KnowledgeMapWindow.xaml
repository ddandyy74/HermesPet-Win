<Window x:Class="HermesPet.Views.KnowledgeMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="知识图谱"
        Width="800"
        Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <!-- 知识图谱窗口（简化版） -->
    <!-- 参考 macOS: CanvasView.swift（画布视图） -->
    <!-- TODO: 实现完整的知识图谱可视化 -->

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#F0FFFFFF"/>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackground}"
            BorderBrush="#33000000"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="15" ShadowDepth="3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0"
                    Background="#F5F5F5"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <TextBlock Text="知识图谱"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>

                    <Button Content="✕"
                           Width="32"
                           Height="32"
                           FontSize="14"
                           Background="Transparent"
                           BorderThickness="0"
                           Cursor="Hand"
                           HorizontalAlignment="Right"
                           Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- 内容区域（占位符） -->
            <Grid Grid.Row="1" Margin="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🗺️"
                              FontSize="48"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,16"/>

                    <TextBlock Text="知识图谱功能正在开发中"
                              FontSize="18"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="此功能将展示对话中的知识点关系图谱"
                              FontSize="13"
                              Foreground="#666666"
                              HorizontalAlignment="Center"
                              TextWrapping="Wrap"
                              TextAlignment="Center"
                              MaxWidth="400"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
