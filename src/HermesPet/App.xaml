<Application x:Class="HermesPet.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HermesPet"
             xmlns:windows="clr-namespace:HermesPet.Windows"
             xmlns:converters="clr-namespace:HermesPet.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- 状态转换器 -->
        <windows:StateToBackgroundConverter x:Key="StateToBackgroundConverter"/>
        <windows:StateToVisibilityConverter x:Key="StateToVisibilityConverter"/>
        <windows:ConnectionStatusToColorConverter x:Key="ConnectionStatusToColorConverter"/>
        <windows:AgentModeToLabelConverter x:Key="AgentModeToLabelConverter"/>
        
        <!-- 通用转换器 -->
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Application.Resources>
</Application>
